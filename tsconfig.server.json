{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": false,
    "skipLibCheck": true,
    "outDir": ".",
    "rootDir": ".",
    "resolveJsonModule": true,
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": ["server.ts", "lib/gemini-live-bridge.ts", "lib/gemini-session-pool.ts", "lib/supabase-server.ts"],
  "exclude": ["node_modules", ".next"]
}
